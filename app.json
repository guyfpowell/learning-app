{
  "expo": {
    "name": "Learning",
    "slug": "learning-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8FAFC"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.learning.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#4F46E5"
      },
      "package": "com.learning.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "learning-app",
          "organization": "learning"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "learning",
    "extra": {
      "router": {},
      "eas": {
        "projectId": ""
      }
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    }
  }
}
