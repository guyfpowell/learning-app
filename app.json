{
  "expo": {
    "name": "Pocket Change",
    "slug": "pocketchange-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F3F3F3"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "org.pocketchange.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1B5E72"
      },
      "package": "org.pocketchange.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "PocketChange needs camera access to scan recipient QR codes."
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.org.pocketchange.app",
          "enableGooglePay": false
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "pocketchange",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8eea4182-083c-4a25-bb6e-ba6d66fe81bb"
      }
    },
    "owner": "guyfpowell",
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/8eea4182-083c-4a25-bb6e-ba6d66fe81bb"
    }
  }
}
